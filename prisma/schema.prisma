generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Required for Supabase connection pooling
}

model AISummary {
  id          String   @id @default(cuid())
  caseId      String   @unique
  summary     String
  keyPoints   String
  insights    String
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Case {
  id              String           @id @default(cuid())
  caseNumber      String           @unique
  caseTitle       String
  petitionerName  String
  petitionerPhone String?
  respondentName  String
  respondentPhone String?
  clientParty     ClientParty      @default(PETITIONER)
  vakalat         String?
  description     String
  tasks           String?
  status          CaseStatus       @default(ACTIVE)
  priority        Priority         @default(MEDIUM)
  createdById     String
  firmId          String
  courtName       String?
  courtHall       String?
  courtTypeId     String?
  judgeAssigned   String?
  closedAt        DateTime?
  closedById      String?
  closureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  AISummary       AISummary?
  User            User             @relation(fields: [createdById], references: [id])
  Firm            Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  CourtType       CourtType?       @relation(fields: [courtTypeId], references: [id])
  FileDocument    FileDocument[]
  Hearing         Hearing[]
  assignments     CaseAssignment[]
  Todo            Todo[]
  CaseNote        CaseNote[]

  @@index([caseNumber])
  @@index([createdById])
  @@index([firmId])
  @@index([status])
}

model CaseAssignment {
  id         String   @id @default(cuid())
  caseId     String
  userId     String
  assignedAt DateTime @default(now())
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
  @@index([caseId])
  @@index([userId])
}

model FileDocument {
  id         String   @id @default(cuid())
  caseId     String
  fileName   String
  fileUrl    String
  fileType   String
  fileSize     Int
  isFinalOrder Boolean  @default(false)
  uploadedAt   DateTime @default(now())
  Case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Firm {
  id                      String      @id @default(cuid())
  name                    String
  address                 String?
  phone                   String?
  email                   String?
  ownerId                 String      @unique
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  Case                    Case[]
  User_Firm_ownerIdToUser User        @relation("Firm_ownerIdToUser", fields: [ownerId], references: [id])
  User_User_firmIdToFirm  User[]      @relation("User_firmIdToFirm")
  Todo                    Todo[]
  CourtType               CourtType[]
  judgments               Judgment[]

  @@index([ownerId])
}

model CourtType {
  id        String   @id @default(cuid())
  name      String
  firmId    String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  firm      Firm?    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  cases     Case[]

  @@unique([name, firmId])
  @@index([firmId])
}

model Hearing {
  id           String         @id @default(cuid())
  caseId       String
  hearingDate  DateTime
  hearingType  String         @default("ARGUMENTS")
  courtHall    String
  notes        String?
  status       HearingStatus  @default(UPCOMING)
  closureNote  String?
  closedById   String?
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Case         Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  closedBy     User?          @relation("HearingClosedBy", fields: [closedById], references: [id])
  Reminder     Reminder[]
  CalendarSync CalendarSync[]

  @@index([caseId])
  @@index([hearingDate])
  @@index([closedById])
}

model GoogleCalendarToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  calendarId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CalendarSync {
  id            String   @id @default(cuid())
  hearingId     String
  googleEventId String   @unique
  lastSyncedAt  DateTime @default(now())
  syncStatus    String   @default("SYNCED")
  errorMessage  String?
  Hearing       Hearing  @relation(fields: [hearingId], references: [id], onDelete: Cascade)

  @@index([hearingId])
  @@index([googleEventId])
}

model Reminder {
  id           String         @id @default(cuid())
  hearingId    String
  reminderType ReminderType   @default(ONE_DAY_BEFORE)
  reminderTime DateTime
  status       ReminderStatus @default(PENDING)
  sentAt       DateTime?
  createdAt    DateTime       @default(now())
  Hearing      Hearing        @relation(fields: [hearingId], references: [id], onDelete: Cascade)

  @@index([hearingId])
  @@index([reminderTime])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model User {
  id                      String               @id @default(cuid())
  email                   String               @unique
  name                    String?
  password                String?              // Nullable for Google OAuth users
  googleId                String?              @unique // Google 'sub' identifier for OAuth
  firmId                  String?
  role                    UserRole             @default(ADVOCATE)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  Case                    Case[]
  Firm_Firm_ownerIdToUser Firm?                @relation("Firm_ownerIdToUser")
  Session                 Session[]
  Firm_User_firmIdToFirm  Firm?                @relation("User_firmIdToFirm", fields: [firmId], references: [id])
  GoogleCalendarToken     GoogleCalendarToken?
  caseAssignments         CaseAssignment[]
  activityLogs            ActivityLog[]
  hearingsClosed          Hearing[]            @relation("HearingClosedBy")
  passwordResetTokens     PasswordResetToken[]
  todosAssigned           Todo[]               @relation("TodoAssignee")
  todosCreated            Todo[]               @relation("TodoCreator")
  todosClosed             Todo[]               @relation("TodoCloser")
  caseNotes               CaseNote[]
  judgments               Judgment[]            @relation("JudgmentCreator")
  judgmentThreads         JudgmentThread[]      @relation("JudgmentThreadCreator")

  @@index([email])
  @@index([firmId])
  @@index([googleId])
}

model CaseNote {
  id          String   @id @default(cuid())
  caseId      String
  content     String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([caseId])
  @@index([createdById])
}

model Judgment {
  id          String               @id @default(cuid())
  firmId      String
  createdById String
  type        JudgmentType
  category    String
  headnote    String               @db.Text
  citation    String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  firm        Firm                 @relation(fields: [firmId], references: [id], onDelete: Cascade)
  createdBy   User                 @relation("JudgmentCreator", fields: [createdById], references: [id])
  attachments JudgmentAttachment[]
  threads     JudgmentThread[]

  @@index([firmId])
  @@index([createdById])
}

model JudgmentAttachment {
  id         String   @id @default(cuid())
  judgmentId String
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int
  uploadedAt DateTime @default(now())
  judgment   Judgment @relation(fields: [judgmentId], references: [id], onDelete: Cascade)

  @@index([judgmentId])
}

model JudgmentThread {
  id          String   @id @default(cuid())
  judgmentId  String
  content     String   @db.Text
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  judgment    Judgment @relation(fields: [judgmentId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("JudgmentThreadCreator", fields: [createdById], references: [id])

  @@index([judgmentId])
  @@index([createdById])
}

enum JudgmentType {
  RESEARCH
  OFFICE_JUDGMENT
}

enum CaseStatus {
  ACTIVE
  PENDING_JUDGMENT
  CONCLUDED
  APPEAL
  DISMISSED
  CLOSED
}

enum ClientParty {
  PETITIONER
  RESPONDENT
}

enum HearingStatus {
  UPCOMING
  PENDING
  CLOSED
  POSTPONED
  CANCELLED
}

enum TodoStatus {
  PENDING
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ReminderType {
  ONE_DAY_BEFORE
  THREE_DAYS_BEFORE
  ONE_WEEK_BEFORE
  CUSTOM
}

enum UserRole {
  ADVOCATE
  ADMIN
  SUPPORT_STAFF
}

model Todo {
  id           String     @id @default(cuid())
  firmId       String
  caseId       String?
  description  String
  assignedTo   String?
  status         TodoStatus @default(PENDING)
  createdById    String
  closingComment String?
  closedAt       DateTime?
  closedById     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  firm         Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case         Case?      @relation(fields: [caseId], references: [id], onDelete: SetNull)
  assignedUser User?      @relation("TodoAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  createdBy    User       @relation("TodoCreator", fields: [createdById], references: [id], onDelete: Cascade)
  closedBy     User?      @relation("TodoCloser", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([firmId])
  @@index([caseId])
  @@index([assignedTo])
  @@index([closedById])
}

// Rate limiting records (persisted for serverless environments)
model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // email or IP address
  attempts  Int      @default(0)
  resetAt   DateTime // window expiry
  lockedUntil DateTime? // lockout expiry (null = not locked)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([resetAt])
}

// Activity Log for tracking all actions in the system
model ActivityLog {
  id          String       @id @default(cuid())
  userId      String
  firmId      String
  action      ActivityAction
  entityType  EntityType
  entityId    String?      // ID of the affected entity (case, hearing, etc.)
  entityName  String?      // Human-readable name (case number, hearing date, etc.)
  details     String?      @db.Text // JSON string with additional details
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime     @default(now())

  User        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@index([action])
}

enum ActivityAction {
  // Case actions
  CASE_CREATED
  CASE_UPDATED
  CASE_DELETED
  CASE_ASSIGNED
  CASE_UNASSIGNED

  CASE_CLOSED
  CASE_REOPENED

  // Hearing actions
  HEARING_CREATED
  HEARING_UPDATED
  HEARING_DELETED
  HEARING_COMPLETED
  HEARING_CLOSED
  HEARING_POSTPONED

  // Document actions
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  DOCUMENT_VIEWED

  // AI actions
  AI_ANALYSIS_RUN
  AI_DOCUMENT_ANALYSIS
  AI_CUSTOM_QUERY

  // Team actions
  MEMBER_INVITED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED

  // Auth actions
  USER_LOGIN
  USER_LOGOUT
  PASSWORD_CHANGED

  // Calendar actions
  CALENDAR_CONNECTED
  CALENDAR_DISCONNECTED
  CALENDAR_SYNCED

  // Judgment actions
  JUDGMENT_CREATED
  JUDGMENT_UPDATED
  JUDGMENT_DELETED
}

enum EntityType {
  CASE
  HEARING
  DOCUMENT
  USER
  FIRM
  CALENDAR
  AI_ANALYSIS
  JUDGMENT
}
